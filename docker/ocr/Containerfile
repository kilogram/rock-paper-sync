# OCR Service Container for TrOCR inference and fine-tuning
# Accepts any base image with Python and uv installed
#
# Build examples:
#   podman build --build-arg BASE_IMAGE=docker.io/pytorch/pytorch:2.1.0-cuda12.1-cudnn8-runtime -t ocr:cuda -f Containerfile.multi .
#   podman build --build-arg BASE_IMAGE=localhost/ml-base-npu:latest -t ocr:npu -f Containerfile.multi .
#   podman build --build-arg BASE_IMAGE=docker.io/python:3.12-slim -t ocr:cpu -f Containerfile.multi .

ARG BASE_IMAGE=docker.io/python:3.12-slim
FROM ${BASE_IMAGE}

# Common environment
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV TRANSFORMERS_CACHE=/app/models
ENV HF_HOME=/app/models

WORKDIR /app

# Create directories
RUN mkdir -p /app/models /app/data /app/checkpoints

# Install uv if not present, then install dependencies
COPY requirements.txt .
RUN command -v uv >/dev/null 2>&1 || (curl -LsSf https://astral.sh/uv/install.sh | sh); \
    export PATH="/root/.local/bin:${PATH}"; \
    uv pip install --system --no-cache -r requirements.txt

ENV PATH="/root/.local/bin:${PATH}"

# Pre-download base model (speeds up cold starts)
RUN python -c "from transformers import TrOCRProcessor, VisionEncoderDecoderModel; \
    TrOCRProcessor.from_pretrained('microsoft/trocr-base-handwritten'); \
    VisionEncoderDecoderModel.from_pretrained('microsoft/trocr-base-handwritten')"

# Copy service code
COPY src/ocr_service /app/ocr_service

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=5)" || exit 1

ENTRYPOINT ["python", "-m", "ocr_service"]
CMD ["serverless"]
